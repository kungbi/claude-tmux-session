#!/bin/bash
# claude-watch — lightweight polling watcher for claude-tmux-session

interval=2
cwd=""
claude_pane=""

# Argument parsing
while [ $# -gt 0 ]; do
  case "$1" in
    --interval)
      interval="$2"; shift 2 ;;
    --cwd)
      cwd="$2"; shift 2 ;;
    --claude-pane)
      claude_pane="$2"; shift 2 ;;
    *)
      shift ;;
  esac
done

# Change to working directory if provided
if [ -n "$cwd" ]; then
  cd "$cwd" || exit 1
fi

export GIT_PAGER=cat

trap 'exit 0' INT TERM

prev_content=""

while true; do
  # Layer 3 watchdog: exit if the tracked pane is gone
  if [ -n "$claude_pane" ]; then
    if ! tmux list-panes -a -F '#{pane_id}' 2>/dev/null | grep -qF "$claude_pane"; then
      exit 0
    fi
  fi

  # Build content (timestamp excluded from diff check so unchanged files don't flicker)
  if git rev-parse --is-inside-work-tree > /dev/null 2>&1; then
    new_content=$(
      echo "── Changed ──"
      git diff --stat HEAD 2>/dev/null
      echo ""
      echo "── Status ──"
      git status --short 2>/dev/null | head -10
      echo ""
      echo "── Recent edits (10m) ──"
      find . -type f -mmin -10 \
        -not -path './.git/*' \
        -not -path './node_modules/*' \
        -not -path './.omc/*' \
        -not -path './.cache/*' \
        2>/dev/null | LC_ALL=C tr -d '\000-\010\013-\037' | head -15
    )
  else
    new_content=$(
      echo "Not a git repository — showing recent file edits only"
      echo ""
      echo "── Recent edits (10m) ──"
      find . -type f -mmin -10 \
        -not -path './.git/*' \
        -not -path './node_modules/*' \
        -not -path './.omc/*' \
        -not -path './.cache/*' \
        2>/dev/null | LC_ALL=C tr -d '\000-\010\013-\037' | head -15
    )
  fi

  # Only redraw when content changes — eliminates flicker during idle
  if [ "$new_content" != "$prev_content" ]; then
    printf '\033[2J\033[H'
    echo "~ claude-watch | $(basename "${cwd:-$PWD}") | $(date +%H:%M:%S)"
    echo ""
    printf '%s\n' "$new_content"
    prev_content="$new_content"
  fi

  sleep "$interval"
done
