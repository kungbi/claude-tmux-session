#!/bin/zsh
# claude-tmux - Claude Code tmux session manager CLI

_CLAUDE_TMUX_SCRIPT_URL="https://raw.githubusercontent.com/kungbi/claude-tmux-session/main/claude-tmux-session.zsh"
_CLAUDE_TMUX_STAMP_DIR="${HOME}/.cache/claude-sessions"

_ctm_install_path() {
  local brew_prefix
  brew_prefix=$(brew --prefix 2>/dev/null)
  if [[ -z "$brew_prefix" ]]; then
    local _p
    for _p in /opt/homebrew /usr/local; do
      [[ -d "$_p/Cellar" ]] && brew_prefix="$_p" && break
    done
  fi
  if [[ -n "$brew_prefix" && -f "${brew_prefix}/share/claude-tmux-session/claude-tmux-session.zsh" ]]; then
    echo "${brew_prefix}/share/claude-tmux-session/claude-tmux-session.zsh"
  elif [[ -f "${HOME}/.local/share/claude-tmux-session/claude-tmux-session.zsh" ]]; then
    echo "${HOME}/.local/share/claude-tmux-session/claude-tmux-session.zsh"
  fi
}

_ctm_is_brew() {
  brew list claude-tmux-session &>/dev/null 2>&1
}

_ctm_version() {
  local _install_path version line
  _install_path=$(_ctm_install_path)
  if [[ -n "$_install_path" ]]; then
    line=$(grep '^_CLAUDE_TMUX_VERSION=' "$_install_path" 2>/dev/null)
    version="${line#*\"}"
    version="${version%\"*}"
  fi
  printf 'claude-tmux-session %s\n' "${version:-unknown}"
}

_ctm_update() {
  if _ctm_is_brew; then
    printf '\033[1;36m[claude-tmux]\033[0m Installed via Homebrew. Upgrading...\n'
    brew update && brew upgrade claude-tmux-session
    printf '\033[1;33m[claude-tmux]\033[0m Apply: source ~/.zshrc\n'
    return
  fi

  local install_path="${HOME}/.local/share/claude-tmux-session/claude-tmux-session.zsh"
  local tmp current_version new_version
  tmp=$(mktemp /tmp/claude-tmux-session.XXXXXX.zsh)
  trap "rm -f '$tmp'" EXIT INT TERM
  printf '\033[1;36m[claude-tmux]\033[0m Checking for updates...\n'

  if ! curl -fsSL "$_CLAUDE_TMUX_SCRIPT_URL" -o "$tmp"; then
    printf '\033[1;31m[claude-tmux]\033[0m Download failed\n'
    return 1
  fi

  current_version=$(grep '^_CLAUDE_TMUX_VERSION=' "$install_path" 2>/dev/null | cut -d'"' -f2)
  new_version=$(grep '^_CLAUDE_TMUX_VERSION=' "$tmp" | cut -d'"' -f2)

  if [[ "$new_version" == "$current_version" ]]; then
    printf '\033[1;36m[claude-tmux]\033[0m Already up to date (%s)\n' "$current_version"
    return 0
  fi

  trap - EXIT INT TERM
  mkdir -p "${install_path:h}"
  mv "$tmp" "$install_path"
  printf '\033[1;32m[claude-tmux]\033[0m Updated: %s → %s\n' "$current_version" "$new_version"
  printf '\033[1;33m[claude-tmux]\033[0m Apply: source ~/.zshrc\n'
}

_ctm_status() {
  local sessions
  sessions=($(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^claude_"))
  if (( ${#sessions[@]} == 0 )); then
    printf 'No active sessions\n'
    return
  fi
  local now s created elapsed hrs mins secs attached i=1
  now=$(date +%s)
  for s in "${sessions[@]}"; do
    created=$(tmux display-message -t "$s" -p "#{session_created}" 2>/dev/null)
    attached=$(tmux display-message -t "$s" -p "#{session_attached}" 2>/dev/null)
    if [[ -n "$created" ]]; then
      elapsed=$((now - created))
      hrs=$(( elapsed / 3600 ))
      mins=$(( (elapsed % 3600) / 60 ))
      secs=$(( elapsed % 60 ))
      if (( hrs > 0 )); then
        local age="${hrs}h ${mins}m"
      elif (( mins > 0 )); then
        local age="${mins}m ${secs}s"
      else
        local age="${secs}s"
      fi
    else
      local age="unknown"
    fi
    if [[ "$attached" == "1" ]]; then
      printf '[%d] %s (running, %s elapsed)\n' "$i" "$s" "$age"
    else
      printf '[%d] %s (idle, %s elapsed)\n' "$i" "$s" "$age"
    fi
    i=$((i + 1))
  done
}

_ctm_kill() {
  local sessions
  sessions=($(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^claude_"))
  if (( ${#sessions[@]} == 0 )); then
    printf 'No active sessions\n'
    return
  fi

  if [[ -n "$1" ]]; then
    if [[ ! "$1" =~ ^[0-9]+$ ]] || (( $1 < 1 || $1 > ${#sessions[@]} )); then
      printf 'Invalid session number: %s (expected 1..%d)\n' "$1" "${#sessions[@]}" >&2
      return 1
    fi
    local target="${sessions[$1]}"
    printf 'Kill session %s? [y/N]: ' "$target"
    read -k 1 confirm
    printf '\n'
    if [[ "$confirm" =~ ^[yY]$ ]]; then
      tmux kill-session -t "$target" 2>/dev/null
      rm -f "${_CLAUDE_TMUX_STAMP_DIR}/$target"
      printf 'Killed: %s\n' "$target"
    else
      printf 'Canceled.\n'
    fi
    return
  fi

  local idle_sessions=()
  local attached
  for s in "${sessions[@]}"; do
    attached=$(tmux display-message -t "$s" -p "#{session_attached}" 2>/dev/null)
    [[ "$attached" != "1" ]] && idle_sessions+=("$s")
  done

  if (( ${#idle_sessions[@]} == 0 )); then
    printf 'No idle sessions to kill\n'
    return
  fi

  printf 'Kill %d idle session(s)? [y/N]: ' "${#idle_sessions[@]}"
  read -k 1 confirm
  printf '\n'
  if [[ "$confirm" =~ ^[yY]$ ]]; then
    for s in "${idle_sessions[@]}"; do
      tmux kill-session -t "$s" 2>/dev/null
      rm -f "${_CLAUDE_TMUX_STAMP_DIR}/$s"
      printf 'Killed: %s\n' "$s"
    done
  else
    printf 'Canceled.\n'
  fi
}

_ctm_alias() {
  local zshrc="${ZDOTDIR:-$HOME}/.zshrc"
  if [[ -z "$1" ]]; then
    local found
    found=$(grep "^alias .*='claude-tmux'" "$zshrc" 2>/dev/null)
    if [[ -n "$found" ]]; then
      printf 'Registered aliases:\n'
      printf '  %s\n' "${found[@]}"
    else
      printf 'No aliases registered.\n'
      printf 'Usage: claude-tmux alias <name>\n'
    fi
    return
  fi

  local name="$1"
  local line="alias ${name}='claude-tmux'"

  if grep -qF "$line" "$zshrc" 2>/dev/null; then
    printf '\033[1;33m[claude-tmux]\033[0m alias '\''%s'\'' is already registered.\n' "$name"
    return
  fi

  printf "Add alias '%s' to %s\n" "$name" "$zshrc"
  printf 'Are you sure? [y/N]: '
  read -k 1 confirm
  printf '\n'

  if [[ "$confirm" =~ ^[yY]$ ]]; then
    printf '\n# claude-tmux alias\n%s\n' "$line" >> "$zshrc"
    printf '\033[1;32m[claude-tmux]\033[0m alias '\''%s'\'' added. Apply: source ~/.zshrc\n' "$name"
  else
    printf '[claude-tmux] Canceled.\n'
  fi
}

_ctm_on() {
  local flag="${_CLAUDE_TMUX_STAMP_DIR}/.disabled"
  if [[ ! -f "$flag" ]]; then
    printf '[claude-tmux] Already enabled.\n'
    return
  fi
  rm -f "$flag"
  printf '\033[1;32m[claude-tmux]\033[0m Enabled.\n'
}

_ctm_off() {
  local flag="${_CLAUDE_TMUX_STAMP_DIR}/.disabled"
  if [[ -f "$flag" ]]; then
    printf '[claude-tmux] Already disabled.\n'
    return
  fi
  mkdir -p "$_CLAUDE_TMUX_STAMP_DIR"
  touch "$flag"
  printf '\033[1;33m[claude-tmux]\033[0m Disabled. Run '\''claude-tmux on'\'' to re-enable.\n'
}

_ctm_uninstall() {
  local zshrc="${ZDOTDIR:-$HOME}/.zshrc"

  printf '\033[1;31m[claude-tmux]\033[0m This will remove claude-tmux-session completely.\n'
  printf 'Are you sure? [y/N]: '
  read -k 1 confirm
  printf '\n'
  [[ "$confirm" =~ ^[yY]$ ]] || { printf 'Canceled.\n'; return; }

  if _ctm_is_brew; then
    brew uninstall claude-tmux-session
  else
    rm -rf "${HOME}/.local/share/claude-tmux-session"
    rm -f "${HOME}/.local/bin/claude-tmux"
    printf 'Removed local files.\n'
  fi

  # remove source line from ~/.zshrc
  if grep -q 'claude-tmux-session.zsh' "$zshrc" 2>/dev/null; then
    local tmp
    tmp=$(mktemp)
    grep -v 'claude-tmux-session.zsh' "$zshrc" > "$tmp" && mv "$tmp" "$zshrc"
    printf 'Removed source line from %s\n' "$zshrc"
  fi

  # remove stamp dir
  rm -rf "${_CLAUDE_TMUX_STAMP_DIR}"

  printf '\033[1;32m[claude-tmux]\033[0m Uninstalled. Run '\''source ~/.zshrc'\'' to apply.\n'
}

_ctm_clean() {
  local count=0 f sname
  for f in "${_CLAUDE_TMUX_STAMP_DIR}"/claude_*(N); do
    sname="${f##*/}"
    if ! tmux has-session -t "$sname" 2>/dev/null; then
      rm -f "$f"
      count=$((count + 1))
    fi
  done
  printf '%d stamp file(s) cleaned up\n' "$count"
}

case "$1" in
  version|--version|-v)
    _ctm_version
    ;;
  update|--update)
    _ctm_update
    ;;
  ls)
    _ctm_status
    ;;
  clean)
    _ctm_clean
    ;;
  alias)
    _ctm_alias "$2"
    ;;
  kill)
    _ctm_kill "$2"
    ;;
  on)
    _ctm_on
    ;;
  off)
    _ctm_off
    ;;
  uninstall)
    _ctm_uninstall
    ;;
  ""|--help|-h)
    printf 'Usage: claude-tmux <command>\n\n'
    printf 'Commands:\n'
    printf '  version      print current version\n'
    printf '  update       update to latest version\n'
    printf '  ls           list active sessions\n'
    printf '  clean        remove expired stamp files\n'
    printf '  alias <name> register a short alias (e.g. ct)\n'
    printf '  kill [n]     kill idle sessions (or session n)\n'
    printf '  on           enable session manager\n'
    printf '  off          disable session manager\n'
    printf '  uninstall    remove claude-tmux-session completely\n'
    ;;
  *)
    printf 'Unknown command: %s\n' "$1" >&2
    printf 'Run "claude-tmux --help" for usage.\n' >&2
    exit 1
    ;;
esac
