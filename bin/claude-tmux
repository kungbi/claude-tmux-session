#!/bin/zsh
# claude-tmux - Claude Code tmux session manager CLI

_CLAUDE_TMUX_SCRIPT_URL="https://raw.githubusercontent.com/kungbi/claude-tmux-session/main/claude-tmux-session.zsh"
_CLAUDE_TMUX_STAMP_DIR="${HOME}/.cache/claude-sessions"

_ctm_install_path() {
  local brew_prefix
  brew_prefix=$(brew --prefix 2>/dev/null)
  if [[ -z "$brew_prefix" ]]; then
    local _p
    for _p in /opt/homebrew /usr/local; do
      [[ -d "$_p/Cellar" ]] && brew_prefix="$_p" && break
    done
  fi
  if [[ -n "$brew_prefix" && -f "${brew_prefix}/share/claude-tmux-session/claude-tmux-session.zsh" ]]; then
    echo "${brew_prefix}/share/claude-tmux-session/claude-tmux-session.zsh"
  elif [[ -f "${HOME}/.local/share/claude-tmux-session/claude-tmux-session.zsh" ]]; then
    echo "${HOME}/.local/share/claude-tmux-session/claude-tmux-session.zsh"
  fi
}

_ctm_is_brew() {
  brew list claude-tmux-session &>/dev/null 2>&1
}

_ctm_version() {
  local _install_path version line
  _install_path=$(_ctm_install_path)
  if [[ -n "$_install_path" ]]; then
    line=$(grep '^_CLAUDE_TMUX_VERSION=' "$_install_path" 2>/dev/null)
    version="${line#*\"}"
    version="${version%\"*}"
  fi
  printf 'claude-tmux-session %s\n' "${version:-unknown}"
}

_ctm_update() {
  if _ctm_is_brew; then
    printf '\033[1;36m[claude-tmux]\033[0m Installed via Homebrew. Upgrading...\n'
    brew update && brew upgrade claude-tmux-session
    return
  fi

  local install_path="${HOME}/.local/share/claude-tmux-session/claude-tmux-session.zsh"
  local tmp current_version new_version
  tmp=$(mktemp /tmp/claude-tmux-session.XXXXXX.zsh)
  trap "rm -f '$tmp'" EXIT INT TERM
  printf '\033[1;36m[claude-tmux]\033[0m Checking for updates...\n'

  if ! curl -fsSL "$_CLAUDE_TMUX_SCRIPT_URL" -o "$tmp"; then
    printf '\033[1;31m[claude-tmux]\033[0m Download failed\n'
    return 1
  fi

  current_version=$(grep '^_CLAUDE_TMUX_VERSION=' "$install_path" 2>/dev/null | cut -d'"' -f2)
  new_version=$(grep '^_CLAUDE_TMUX_VERSION=' "$tmp" | cut -d'"' -f2)

  if [[ "$new_version" == "$current_version" ]]; then
    printf '\033[1;36m[claude-tmux]\033[0m Already up to date (%s)\n' "$current_version"
    return 0
  fi

  trap - EXIT INT TERM
  mkdir -p "${install_path:h}"
  mv "$tmp" "$install_path"
  printf '\033[1;32m[claude-tmux]\033[0m Updated: %s → %s\n' "$current_version" "$new_version"
  printf '\033[1;33m[claude-tmux]\033[0m Apply: source ~/.zshrc\n'
}

_ctm_status() {
  local sessions
  sessions=($(tmux list-sessions -F "#{session_name}" 2>/dev/null | grep "^claude_"))
  if (( ${#sessions[@]} == 0 )); then
    printf 'No active sessions\n'
    return
  fi
  local now s saved elapsed mins secs
  now=$(date +%s)
  for s in "${sessions[@]}"; do
    local stamp_file="${_CLAUDE_TMUX_STAMP_DIR}/$s"
    if [[ -f "$stamp_file" ]]; then
      saved=$(< "$stamp_file")
      elapsed=$((now - saved))
      mins=$(( elapsed / 60 ))
      secs=$(( elapsed % 60 ))
      if (( mins > 0 )); then
        printf '%s (%d min ago)\n' "$s" "$mins"
      else
        printf '%s (%d sec ago)\n' "$s" "$secs"
      fi
    else
      printf '%s (active)\n' "$s"
    fi
  done
}

_ctm_clean() {
  local count=0 f sname
  for f in "${_CLAUDE_TMUX_STAMP_DIR}"/claude_*(N); do
    sname="${f##*/}"
    if ! tmux has-session -t "$sname" 2>/dev/null; then
      rm -f "$f"
      count=$((count + 1))
    fi
  done
  printf '%d stamp file(s) cleaned up\n' "$count"
}

case "$1" in
  version|--version|-v)
    _ctm_version
    ;;
  update|--update)
    _ctm_update
    ;;
  ls|status)
    _ctm_status
    ;;
  clean)
    _ctm_clean
    ;;
  ""|--help|-h)
    printf 'Usage: claude-tmux <command>\n\n'
    printf 'Commands:\n'
    printf '  version   print current version\n'
    printf '  update    update to latest version\n'
    printf '  ls        list active sessions\n'
  printf '  status    alias for ls\n'
    printf '  clean     remove expired stamp files\n'
    ;;
  *)
    printf 'Unknown command: %s\n' "$1" >&2
    printf 'Run "claude-tmux --help" for usage.\n' >&2
    exit 1
    ;;
esac
